# Haven - Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!

# Project Configuration
PROJECT_NAME="Haven"
DEBUG=False
HTTPS_ONLY=False

# AI Model Provider: Ollama, Gemini, or Fanar
MODEL_PROVIDER="Ollama"

# Ollama Configuration (local LLM)
OLLAMA_MODEL="command-r7b-arabic:latest"

# Google Gemini Configuration
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL_NAME="gemini-2.5-flash-lite"

# Fanar API Configuration
Fanar_API_KEY="your_fanar_api_key_here"

# MongoDB Configuration
MONGODB_URL="mongodb://admin:admin123@mongodb:27017/haven_db?authSource=admin"
DATABASE_NAME="haven_db"

# LangFuse Configuration (Observability)
LANGFUSE_PUBLIC_KEY="pk-lf-your_key_here"
LANGFUSE_SECRET_KEY="sk-lf-your_key_here"
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# Session & Security
SESSION_SECRET_KEY="your_super_secret_key_min_32_chars_here_12345"

# Timezone
TIME_ZONE="Asia/Gaza"

# Offline Mode (Set to True for dummy/offline mode)
Electricity_Off=False

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:8000,http://localhost:3000"
